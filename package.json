  "bugs": {
    "url": "https://github.com/Eden-Labs-Community/eden-labs-core/issues"
  },
  "homepage": "https://github.com/Eden-Labs-Community/eden-labs-core#readme",
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/uuid": "^10.0.0",
    "jest": "^30.3.0",
    "ts-jest": "^29.4.6",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "uuid": "^13.0.0"
  }
}
